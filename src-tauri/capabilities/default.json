{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Filesystem access is granted at runtime for the one folder the user picks, so no path scope is listed here.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-write-file",
    "fs:allow-read-dir",
    "fs:allow-mkdir",
    "fs:allow-exists"
  ]
}
